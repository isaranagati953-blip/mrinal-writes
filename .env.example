# ─────────────────────────────────────────────────────────
# LOCAL DEV  →  use the sqlite file below, comment out Turso
# VERCEL/PROD → comment out sqlite, use Turso lines instead
# ─────────────────────────────────────────────────────────

# ── LOCAL SQLite (dev on your Mac) ───────────────────────
DATABASE_URL="file:./dev.db"

# ── Turso (production / Vercel) ──────────────────────────
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# ─── AUTH ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_run_openssl_rand_base64_32"
SESSION_DURATION="7d"

# ─── VAULT SLUG ──────────────────────────────────────────
# Pick something unguessable — this is the secret path members use
# e.g. "morning-light-3847" or "vrindavan-9x2k"
VAULT_SLUG="change-this-to-something-unguessable"
NEXT_PUBLIC_VAULT_SLUG="change-this-to-something-unguessable"

# ─── CLOUDFLARE R2 ───────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"

# ─── EMAIL / SMTP ────────────────────────────────────────
# Gmail: enable 2FA → create an App Password at myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="your@gmail.com"

# ─── APP URL ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# On Vercel: NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
# On production: NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ─── ADMIN (seed script only) ────────────────────────────
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD="choose-a-very-strong-password-16-chars-min"
ADMIN_NAME="Your Name"
